# ══════════════════════════════════════════════════════════════
# PREMIUM TEMPLATES — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# ══════════════════════════════════════════════════════════════

# ──────────────────────────────────────
# ENVIRONNEMENT
# ──────────────────────────────────────
# Valeurs: development | staging | production
NODE_ENV=development

# ──────────────────────────────────────
# EMAIL — RESEND
# Obtenir la clé sur https://resend.com (gratuit jusqu'à 3000 emails/mois)
# Utilisé côté SERVEUR uniquement (API Routes Next.js)
# ──────────────────────────────────────
RESEND_API_KEY=re_PxEuTj2F_G4NPFVFqtFnHydbAxDmAZYV6

# Adresse d'expédition (doit être un domaine vérifié dans Resend)
# En développement: onboarding@resend.dev fonctionne sans vérification
EMAIL_FROM=onboarding@resend.dev  #noreply@votredomaine.cm

# ──────────────────────────────────────
# REDIS — Rate Limiting anti-spam
# ──────────────────────────────────────
# Local (Docker): redis://localhost:6379
# Upstash (cloud gratuit): rediss://default:TOKEN@HOST.upstash.io:PORT
REDIS_URL=redis://localhost:6379

