# ══════════════════════════════════════════════════════════════
# TEMPLATE CORPORATE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# ══════════════════════════════════════════════════════════════

# Environnement
NODE_ENV=development

# ── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_CORPORATE_SITE_URL=http://localhost:3001
NEXT_PUBLIC_CORPORATE_SITE_NAME=Dupont & Associés

# ── Email (Resend) — SERVEUR UNIQUEMENT ──────────────────────
# Ne jamais préfixer avec NEXT_PUBLIC_ !
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@votredomaine.cm
CORPORATE_CONTACT_EMAIL_TO=contact@dupont-associes.cm

# ── WhatsApp Business ────────────────────────────────────────
NEXT_PUBLIC_CORPORATE_WHATSAPP=237699000001

# ── Redis (Rate Limiting) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Analytics (optionnel) ────────────────────────────────────
NEXT_PUBLIC_CORPORATE_GA_ID=G-XXXXXXXXXX

# ── SEO ──────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_VERIFICATION=xxxxxxxxxxxx
